{
  "name": "locky",
  "version": "0.0.1",
  "description": "Secure and private password manager",
  "main": "main.js",
  "author": "raphpay",
  "license": "none",
  "private": false,
  "scripts": {
    "dev": "concurrently \"yarn dev:frontend\" \"yarn dev:electron\"",
    "dev:frontend": "cd frontend && yarn dev",
    "dev:electron": "wait-on http://localhost:5173 && electron .",
    "build": "electron-builder",
    "dev-two": "concurrently \"yarn --cwd frontend dev\" \"wait-on http://localhost:5173 && electron .\"",
    "build-two": "yarn --cwd frontend build",
    "build-three": "cd frontend && yarn build",
    "make": "electron-forge make",
    "start": "electron ."
  },
  "build": {
    "appId": "com.twinpaw.locky",
    "productName": "Locky",
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": "nsis",
      "icon": "assets/icons/icon.ico"
    },
    "mac": {
      "target": "dmg",
      "icon": "assets/icons/icon.icns"
    }
  },
  "devDependencies": {
    "@electron-forge/cli": "^7.11.1",
    "concurrently": "^9.2.1",
    "elecron": "^0.0.1-security",
    "electron": "^40.1.0",
    "electron-builder": "^26.8.1",
    "wait-on": "^9.0.3"
  },
  "dependencies": {
    "electron-serve": "^3.0.1"
  }
}
